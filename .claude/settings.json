{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "defaultMode": "plan"
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "& '.claude/hooks/safety-check.ps1'",
            "shell": "powershell",
            "timeout": 10,
            "statusMessage": "Safety check..."
          }
        ]
      }
    ]
  }
}
