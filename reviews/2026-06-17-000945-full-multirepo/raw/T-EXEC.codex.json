[{"id":"T-EXEC-1","severity":"high","file":"src/trading_bot/execution/alpaca_paper.py","line":"128","issue":"Protective-order dedup fails open: any error fetching open SELL orders returns an empty set, so the caller can incorrectly conclude no protection exists and submit duplicate OCO exits.","evidence":"open_protective_symbols wraps the entire broker query in `except Exception: return set()`. A transient API/auth/network failure is indistinguishable from 'no open protective orders'.","fix":"On broker/query failure, propagate the error or return an explicit failure state so protection submission is blocked rather than dedup being bypassed.","confidence":"high"},{"id":"T-EXEC-2","severity":"high","file":"src/trading_bot/execution/order_router.py","line":"87","issue":"Duplicate-entry guard only checks existing open positions, not already-submitted/open entry orders, so repeated triggers in the same cycle can submit the same symbol multiple times before the position appears.","evidence":"PortfolioState contains `open_symbols`, `open_positions`, and `orders_today` only; `should_trade` rejects duplicates solely with `if sym in {str(s).upper() for s in state.open_symbols}` and has no pending-order/idempotency key check.","fix":"Track open/pending orders per symbol and reject when an entry for the symbol is already accepted/submitted but not fully resolved.","confidence":"high"},{"id":"T-EXEC-3","severity":"high","file":"src/trading_bot/execution/order_router.py","line":"59","issue":"Router can approve orders without any buying-power or cash check, allowing sizes that exceed available funds and causing avoidable broker rejects or retry loops.","evidence":"size_position uses only `equity * risk_per_trade_pct` and `max_notional_per_position`; PortfolioState has no cash/buying_power fields and should_trade never compares `qty * entry` against available funds.","fix":"Add buying_power/cash to PortfolioState and cap or reject when estimated notional exceeds available capital after buffers.","confidence":"high"},{"id":"T-EXEC-4","severity":"medium","file":"src/trading_bot/execution/order_router.py","line":"59","issue":"Position sizing uses binary floats and floor-division on money values, which can mis-round share counts at boundary conditions.","evidence":"`dollar_risk = eq * (config.risk_per_trade_pct / 100.0)` and `shares = int(dollar_risk // risk_per_share)` operate on floats; values like 0.1/0.3 are not exact and can under/over-count shares by 1 near thresholds.","fix":"Use Decimal with explicit quantization for prices/risk and compute integer share count from exact decimal arithmetic.","confidence":"high"},{"id":"T-EXEC-5","severity":"high","file":"src/trading_bot/execution/alpaca_paper.py","line":"68","issue":"Bracket entry is always submitted as a market order even though the API accepts an `entry` parameter and sizing is based on that planned entry, creating slippage-driven oversizing and incorrect realized risk.","evidence":"submit_bracket takes `entry` but constructs `MarketOrderRequest(...)` without using it; returned result records `entry=float(entry)` as if it were the execution basis.","fix":"Either submit a limit entry keyed to the planned price or recompute/validate risk from the actual fill before accepting the position.","confidence":"high"},{"id":"T-EXEC-6","severity":"medium","file":"src/trading_bot/execution/alpaca_paper.py","line":"205","issue":"close_position ignores its `price` parameter and always calls broker market-close, so callers can believe they requested a priced exit while the code exits at market.","evidence":"Method signature is `close_position(self, symbol, *, price: float | None = None)` but the implementation only does `self._client.close_position(sym)` and never uses `price`.","fix":"Remove the unused price parameter or implement the corresponding limit/stop exit path so the behavior matches the call contract.","confidence":"high"}]
