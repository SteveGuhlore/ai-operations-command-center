[{"id":"A-LIVE-1","severity":"critical","file":"runner/ledger/tony_live_guard.py","line":"24","issue":"Live trading opt-in is fail-open for common falsey strings: any non-empty TONY_LIVE_ENABLED value, including '0' or 'false', enables live.","evidence":"The gate checks `if not os.environ.get(\"TONY_LIVE_ENABLED\")`; strings like '0'/'false' are truthy and therefore satisfy the opt-in.","fix":"Require an explicit allowlist such as `os.environ.get(\"TONY_LIVE_ENABLED\", \"\").strip().lower() == \"true\"`.","confidence":"high"},{"id":"A-LIVE-2","severity":"high","file":"runner/ledger/tony_live_guard.py","line":"29","issue":"NaN win rates can bypass the live-trading track-record gate.","evidence":"`win = float(record.get(\"tony_win_rate\", 0) or 0)` accepts `float('nan')`, and `nan < MIN_WIN_RATE` is False, so no rejection reason is added.","fix":"Reject non-finite values with `math.isfinite(win)` before comparing thresholds.","confidence":"high"},{"id":"A-LIVE-3","severity":"medium","file":"runner/ledger/account_mode.py","line":"58","issue":"Live-account isolation check only compares API keys, not secrets, so partially reused production credentials can pass the guard.","evidence":"The code rejects only `live_key == os.environ.get(\"ALPACA_API_KEY\")`; `TONY_LIVE_ALPACA_SECRET_KEY` is never compared to `ALPACA_SECRET_KEY`.","fix":"Validate both live key and live secret differ from the bot account credentials.","confidence":"med"},{"id":"A-BREAKER-1","severity":"critical","file":"runner/ledger/drawdown_breaker.py","line":"153","issue":"The drawdown breaker fails open when the realized-ledger file is missing/corrupt: it returns no rows, which clears consecutive-loss halts.","evidence":"`load_realized_rows()` catches file/JSON errors and returns `[]`; `current_breaker()` feeds that into `breaker_state()`, and `consecutive_losses([])` returns 0.","fix":"Treat unreadable realized-ledger state as breaker-halted or propagate an explicit guard failure to the caller.","confidence":"high"},{"id":"A-BREAKER-2","severity":"critical","file":"runner/ledger/drawdown_breaker.py","line":"167","issue":"The drawdown component fails open when equity history is missing/corrupt: drawdown becomes 0% and the breaker disengages.","evidence":"`_load_equity_series()` returns `[]` on file/shape/parse errors, and `max_drawdown_pct([])` returns 0.0.","fix":"Fail closed on missing/corrupt equity history, or persist the last known breaker state and require valid data before reopening.","confidence":"high"},{"id":"A-BREAKER-3","severity":"high","file":"runner/ledger/drawdown_breaker.py","line":"35","issue":"Consecutive-loss counting can use the wrong trade order, understating the trailing losing streak and allowing trades after a halt-worthy sequence.","evidence":"Rows are re-sorted by `(date, exit_order_id or symbol)` instead of an actual exit timestamp; same-day trades without monotonic IDs can be reordered arbitrarily before the backward loss scan.","fix":"Order by a true exit timestamp/sequence from the ledger and reject rows that lack it.","confidence":"high"},{"id":"A-BUDGET-1","severity":"high","file":"runner/ledger/budget.py","line":"25","issue":"Negative spend entries are accepted, allowing caps to be bypassed by reducing `total_usd` or driving balances negative.","evidence":"`record_spend()` adds `cost_usd` directly to totals with no non-negative validation.","fix":"Reject negative or non-finite spend values before mutating the ledger.","confidence":"high"},{"id":"A-BUDGET-2","severity":"high","file":"runner/ledger/budget.py","line":"26","issue":"Budget updates have a read-modify-write race with no locking, so concurrent spend records can clobber each other and undercount usage.","evidence":"`record_spend()` calls `_load_spend()`, mutates the dict, then `_save_spend()` writes the whole file back with no lock or atomic replace.","fix":"Use an interprocess lock plus atomic write/replace for spend-ledger updates.","confidence":"high"},{"id":"A-BUDGET-3","severity":"high","file":"runner/ledger/budget.py","line":"79","issue":"Off-hours budget is uncapped by default and invalid config values also fall back to infinity, which disables the spend guard.","evidence":"`get_offhours_cap()` returns `float(\"inf\")` when the env var is unset or unparsable.","fix":"Use a finite default and treat invalid cap configuration as a closed guard/error state.","confidence":"high"},{"id":"A-RUNWAY-1","severity":"critical","file":"runner/ledger/runway.py","line":"27","issue":"Deleting or corrupting the runway state file resets the pod to 'alive' starting today, effectively reviving an expired system without operator action.","evidence":"`_load()` initializes `started_at` to `date.today()` and returns defaults when `runway.json` is missing/corrupt.","fix":"Persist a durable initial start state and fail closed when the runway file is unreadable or malformed.","confidence":"high"},{"id":"A-RUNWAY-2","severity":"medium","file":"runner/ledger/runway.py","line":"104","issue":"Pause/revive operations race on the shared JSON file and can lose status transitions or revived_count increments.","evidence":"`pause_pod()` and `revive()` both load, mutate, and rewrite `runway.json` with no locking or compare-and-swap.","fix":"Guard runway state changes with a file lock and atomic write.","confidence":"high"},{"id":"A-CLUSTER-1","severity":"high","file":"runner/ledger/cluster_risk.py","line":"148","issue":"Unknown tickers bypass correlation controls entirely, so new symbols/ETFs can evade the cluster cap until the hardcoded map is updated.","evidence":"`cluster_of()` returns 'other' for unmapped symbols, and `over_cluster_cap()` immediately returns False for 'other'.","fix":"Assign unknown symbols to a conservative default cluster or block/unreviewed-map buys until classified.","confidence":"high"},{"id":"A-AUDIT-1","severity":"critical","file":"runner/ledger/decision_audit.py","line":"43","issue":"Audit logging is fail-open: any write error silently drops the decision record and the trading flow can continue with no audit trail.","evidence":"`record_decision()` catches all exceptions, logs a warning, and returns `None`; the module-level doc explicitly says audit failure must never break the cycle.","fix":"Make audit persistence a gating requirement for live trading, or buffer/retry and fail closed when durable logging is unavailable.","confidence":"high"},{"id":"A-AUDIT-2","severity":"high","file":"runner/ledger/decision_audit.py","line":"41","issue":"Concurrent audit writers are unsynchronized, so records can be lost or interleaved under parallel decision/order paths.","evidence":"The file is opened in append mode and written directly with no file lock, atomic append protocol, or fsync.","fix":"Serialize audit appends with an interprocess lock and durable flush/sync.","confidence":"med"}]
