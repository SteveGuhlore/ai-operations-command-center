[{"id":"T-API-1","severity":"critical","file":"src/trading_bot/api/routes/controls.py","line":"95","issue":"State-changing control endpoints have no real authentication/authorization; any network client can invoke them if it can reach the API.","evidence":"`_pin_ok()` returns `True` when `DASHBOARD_ACTION_PIN` is unset (lines 94-96), `_origin_allowed()` allows requests with no `Origin` header (lines 84-86), and `_guard()` performs no user/session/token authorization before endpoints like `/controls/stop-watch`, `/pause-paper`, `/resume-paper`, `/flatten-all`, `/flatten-one`, `/re-protect`, `/trigger-scan`, `/export-bridge`, and `/ack-alert` execute.","fix":"Require strong server-side auth on every control endpoint (for example bearer token or mTLS) and fail closed when no credential is configured.","confidence":"high"},{"id":"T-API-2","severity":"high","file":"src/trading_bot/api/routes/paper.py","line":"114","issue":"Paper-trading positions and P/L are exposed without authentication, leaking sensitive order/position/account data to anyone on the network.","evidence":"`/paper/positions` and `/paper/equity-curve` are plain GET routes with no auth dependency; responses include symbols, quantities, stops, targets, realized/unrealized P/L, timestamps, and `account_label` (lines 114-142 and 183-215).","fix":"Protect paper endpoints with authentication/authorization and restrict fields returned to the minimum needed by the dashboard.","confidence":"high"},{"id":"T-API-3","severity":"high","file":"src/trading_bot/api/routes/vault.py","line":"18","issue":"Vault content is returned directly over unauthenticated endpoints, exposing internal markdown files and potentially secrets or operational notes.","evidence":"`/vault/bridge` returns `latest.read_text(...)` from the vault bridge directory (line 18) and `/insights` returns `n.read_text(...)` for each daily note (line 27), with no authentication or access control.","fix":"Require authentication for vault endpoints and avoid returning raw file contents unless explicitly authorized and sanitized.","confidence":"high"},{"id":"T-API-4","severity":"medium","file":"src/trading_bot/api/routes/vault.py","line":"21","issue":"`/insights` allows unbounded file enumeration and full file reads via the `limit` query parameter, enabling resource exhaustion.","evidence":"`limit` is an unconstrained integer query parameter (line 21) and the handler reads `[:limit]` markdown files fully into memory (lines 26-27); a large `limit` can force the server to load and serialize many large files in one request.","fix":"Clamp `limit` to a small maximum with validation and paginate or truncate file content.","confidence":"high"},{"id":"T-API-5","severity":"low","file":"src/trading_bot/api/routes/controls.py","line":"168","issue":"Money-action denial responses leak environment and deployment state to remote callers.","evidence":"`_guard()` returns `str(exc)` from `MoneyActionForbidden` (line 168); `money_action_decision()` embeds details such as `ENV_ROLE` and whether `TRADINGBOT_PROD_ACCOUNT_ID` is configured in denial messages (env_fence.py lines 62-69).","fix":"Return a generic authorization failure message to clients and keep detailed fence reasons only in server logs.","confidence":"high"}]
